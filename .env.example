# ConfirmAI Environment Variables Example

# Flask Configuration
FLASK_ENV=production
FLASK_APP=app.py
SECRET_KEY=super-secret-key-replace-me

# Security
JWT_SECRET=super-secret-jwt-key-replace-me
CORS_ORIGINS="*"

# Database
# For SQLite (default)
DATABASE_URL=sqlite:///app.db
# For PostgreSQL (production recommendation)
# DATABASE_URL=postgresql://user:password@localhost/confirmai
